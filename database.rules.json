{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        ".validate": "newData.hasChildren(['user_name', 'password_hash', 'color_theme'])"
      }
    },
    "sheets": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        ".validate": "newData.hasChildren(['id', 'user_id', 'week_start'])"
      }
    },
    "sheets_images": {
      ".read": false,
      ".write": false
    }
  }
}
